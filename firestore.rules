rules_version = '2';

// Fly GACA — Firestore security rules.
// Deploy with:  firebase deploy --only firestore:rules
//
// Phase 3 — pilot accounts. Strict per-user isolation: a signed-in pilot can
// read and write only the document tree under their own users/{uid}. There is
// no path by which one user can read another user's profile or logbook.
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }
    // Simple email validation: contains @ and a dot after @, length reasonable.
    function isEmail(email) {
      return email is string
          && email.size() >= 5
          && email.size() <= 254
          && email.matches('^[^@]+@[^@]+\\.[^@]+$');
    }
    // A profile write must carry a sane email, and every field it writes must be
    // one of the known bounded strings — so a compromised client can't stuff the
    // doc with arbitrary or oversized keys. `entitlement` is allowed in the key
    // set because it is preserved across merge-updates; its VALUE is frozen
    // separately by entitlementUntouched(). Field list mirrors PROFILE_FIELDS in
    // src/lib/sync.ts.
    function validProfile() {
      return request.resource.data.email is string
        && isEmail(request.resource.data.email)
        && (!('displayName' in request.resource.data)
            || (request.resource.data.displayName is string
                && request.resource.data.displayName.size() <= 120))
        && (!('homeBase' in request.resource.data)
            || (request.resource.data.homeBase is string
                && request.resource.data.homeBase.size() <= 8))
        && (!('licenceType' in request.resource.data)
            || (request.resource.data.licenceType is string
                && request.resource.data.licenceType.size() <= 40))
        && (!('medicalExpiry' in request.resource.data)
            || (request.resource.data.medicalExpiry is string
                && request.resource.data.medicalExpiry.size() <= 12))
        && (!('lastFlightReview' in request.resource.data)
            || (request.resource.data.lastFlightReview is string
                && request.resource.data.lastFlightReview.size() <= 12))
        && (!('role' in request.resource.data)
            || (request.resource.data.role is string
                && request.resource.data.role.size() <= 20))
        && request.resource.data.keys().hasOnly(
             ['email', 'displayName', 'homeBase', 'licenceType', 'medicalExpiry',
              'lastFlightReview', 'role', 'entitlement']);
    }
    // The entitlement field (the pilot's plan) is written ONLY by Cloud
    // Functions, which use the Admin SDK and bypass these rules. A client may
    // never introduce or change it — so nobody can grant themselves a paid
    // plan by writing to their own profile.
    function entitlementUntouched() {
      return ('entitlement' in request.resource.data)
               == ('entitlement' in resource.data)
        && (!('entitlement' in request.resource.data)
            || request.resource.data.entitlement == resource.data.entitlement);
    }

    // Waitlist — anyone may submit their email; the list is never readable
    // from the client, so addresses stay private. An optional bounded `topic`
    // records what the person is waiting for (e.g. a `soon` exam-prep pack id).
    match /waitlist/{entry} {
      allow create: if isEmail(request.resource.data.email)
                    && request.resource.data.email.size() >= 5
                    && request.resource.data.email.size() <= 254
                    && (!('topic' in request.resource.data)
                        || (request.resource.data.topic is string
                            && request.resource.data.topic.size() <= 40))
                    && request.resource.data.keys().hasOnly(['email', 'topic']);
      allow read, update, delete: if false;
    }

    // A pilot's own account document.
    match /users/{uid} {
      allow read, delete: if isOwner(uid);
      // On create the client must NOT include an entitlement field at all.
      allow create: if isOwner(uid)
        && validProfile()
        && !('entitlement' in request.resource.data);
      // On update the entitlement must be byte-identical to what is stored,
      // so a client merge can never add, remove or alter it.
      allow update: if isOwner(uid)
        && validProfile()
        && entitlementUntouched();

      // The pilot's logbook — one document per flight.
      match /logbook/{entry} {
        allow read, delete: if isOwner(uid);
        // The client (src/lib/sync.ts flightToDoc) writes EVERY field as a string,
        // including `total` (Flight.total is typed string). Validate `total` as a
        // bounded numeric-looking string (empty, or up to 99999.99) — the old rule
        // required a number, so every real logbook write was denied in production.
        allow create, update: if isOwner(uid)
          && request.resource.data.date is string
          && request.resource.data.date.matches('^([0-9]{4}-[0-9]{2}-[0-9]{2})?$')
          && request.resource.data.total is string
          && request.resource.data.total.matches('^([0-9]{1,5}([.][0-9]{1,2})?)?$')
          && (!('remarks' in request.resource.data)
              || (request.resource.data.remarks is string
                  && request.resource.data.remarks.size() <= 2000))
          && request.resource.data.keys().hasOnly(
               ['date', 'type', 'reg', 'from', 'to', 'total', 'pic', 'night',
                'ifr', 'ldg', 'nightLdg', 'appr', 'remarks']);
      }

      // The pilot's records — ratings, aircraft, documents, endorsements. The
      // client (src/lib/sync.ts recordToDoc) serializes every field as a string.
      // This subcollection had no rule, so the catch-all denied it and records
      // sync failed silently in production.
      match /records/{entry} {
        allow read, delete: if isOwner(uid);
        allow create, update: if isOwner(uid)
          && request.resource.data.category in ['rating', 'aircraft', 'document', 'endorsement']
          && request.resource.data.title is string
          && request.resource.data.title.size() <= 200
          && (!('remarks' in request.resource.data)
              || (request.resource.data.remarks is string
                  && request.resource.data.remarks.size() <= 2000))
          && request.resource.data.keys().hasOnly(
               ['category', 'title', 'ref', 'issued', 'expires', 'remarks']);
      }

      // Study-progress readiness projection (one `summary` doc). The owner
      // writes SCORES + COMPLETION only — never answers (see
      // src/lib/studyProgress.ts toProgressSummary + docs/b2b). The B2B readiness
      // report reads it server-side (Admin SDK). Key-allowlisted, bounded and
      // owner-scoped so a client can't bloat it or read another member's.
      match /progress/{doc} {
        allow read, delete: if isOwner(uid);
        allow create, update: if isOwner(uid)
          && request.resource.data.keys().hasOnly(
               ['quizBest', 'exam', 'examBest', 'examCount', 'gsDone', 'updatedAt'])
          && request.resource.data.updatedAt is string
          && request.resource.data.updatedAt.size() <= 40
          && request.resource.data.quizBest is map
          && request.resource.data.quizBest.keys().size() <= 100
          && request.resource.data.gsDone is map
          && request.resource.data.gsDone.keys().size() <= 100
          && (!('examBest' in request.resource.data)
              || (request.resource.data.examBest is number
                  && request.resource.data.examBest >= 0
                  && request.resource.data.examBest <= 100))
          && (!('examCount' in request.resource.data)
              || (request.resource.data.examCount is int
                  && request.resource.data.examCount >= 0));
      }
    }

    // The uid → Stripe-customer mapping, written ONLY by the billing functions
    // (Admin SDK bypasses rules). No client may read or write it.
    match /stripeCustomers/{uid} {
      allow read, write: if false;
    }

    // Stripe webhook idempotency markers, written ONLY by stripeWebhook (Admin
    // SDK). Explicit deny for parity with stripeCustomers — otherwise it would
    // fall through to the catch-all below.
    match /stripeEvents/{id} {
      allow read, write: if false;
    }

    // School-seat invite roster, keyed by invited email. Provisioned ONLY by an
    // admin (Admin SDK) and read ONLY by the claimSchoolSeat callable to decide a
    // grant — never client-readable/writable, so the roster can't be enumerated or
    // a seat self-forged.
    match /schoolInvites/{email} {
      allow read, write: if false;
    }

    // B2B org (school) records + their member index. Provisioned ONLY by the
    // Admin SDK (the grant-org / grant-school-seats scripts and claimSchoolSeat);
    // read ONLY by the owner-verified getMyOrgs / getCohortReadiness callables.
    // Never client-readable/writable, so a cohort can't be enumerated or forged.
    match /orgs/{orgId} {
      allow read, write: if false;
      match /members/{uid} {
        allow read, write: if false;
      }
    }

    // Per-uid Captain Adel free-question counters, written ONLY by the chat
    // gateway (Admin SDK) to enforce the daily free allowance server-side. A
    // client must never read or write it — the app's own counter is a separate
    // localStorage nudge, not this authoritative record.
    match /chatUsage/{uid} {
      allow read, write: if false;
    }

    // Per-uid purchased Captain Adel credit balance. Written ONLY server-side (the
    // Stripe webhook tops it up; the gateway spends it), but the OWNER may read it
    // so the app can show the balance and lift the daily-limit gate. Never
    // client-writable — a client can't grant itself credits.
    match /chatCredits/{uid} {
      allow read: if isOwner(uid);
      allow write: if false;
    }

    // Per-uid purchased exam-prep packs. Written ONLY by the Stripe webhook (Admin
    // SDK), keyed off a validated `metadata.packId`; the OWNER may read it so the app
    // can unlock owned packs. Never client-writable — a client can't grant itself a
    // pack. Same server-written / owner-readable pattern as chatCredits above.
    match /packEntitlements/{uid} {
      allow read: if isOwner(uid);
      allow write: if false;
    }

    // Referral bookkeeping — the code → referrer mapping and the once-per-referee
    // reward markers. Written ONLY server-side (the referral callable + webhook);
    // the client learns its own code from the callable's return, never by reading
    // here. Fully denied so codes/rewards can't be enumerated or forged.
    match /referralCodes/{code} {
      allow read, write: if false;
    }
    match /referrals/{uid} {
      allow read, write: if false;
    }

    // Licensed-API key hashes and their per-key usage meters. Minted + read only by
    // the backend (Admin SDK / the mint script); the raw key lives with the partner,
    // never here. Fully denied to clients.
    match /apiKeys/{hash} {
      allow read, write: if false;
    }
    match /apiUsage/{hash} {
      allow read, write: if false;
    }

    // Everything else stays denied. Server-only data is written with the Admin
    // SDK (which bypasses these rules); any client reaching an unlisted path is
    // refused here.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}