# Copy to .env.local and fill in. All VITE_* vars are exposed to the client.

# Backend base for the chat/content gateway (default: /api, proxied by the host).
VITE_API_BASE=/api

# Firebase web config (public, non-secret) — wired in Stage 3.
# Copy the values from the Firebase console (Project settings → Your apps → Web).
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=flygaca-app.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=flygaca-app
# VITE_FIREBASE_APP_ID=
# VITE_RECAPTCHA_ENTERPRISE_SITE_KEY=
