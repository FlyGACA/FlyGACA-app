# Copy to .env.local and fill in. All VITE_* vars are exposed to the client.

# Backend base for the chat/content gateway (default: /api, proxied by the host).
VITE_API_BASE=/api

# Firebase web config (public, non-secret). When unset, the app runs fully
# local-first (no auth / no Firestore sync). Set at least the three required keys
# (apiKey, projectId, appId) to turn on Firebase. These are the real values for
# the `flygaca-app` project (Firebase console → Project settings → Your apps →
# Web) — public client identifiers, restricted by Firestore rules + App Check,
# not secrets. Copy this file to `.env.local` to initialize Firebase.
VITE_FIREBASE_API_KEY=AIzaSyCJUd5OS7GYgNYMQEiadVDEdw4MEQc-yaA
VITE_FIREBASE_AUTH_DOMAIN=flygaca-app.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://flygaca-app-default-rtdb.firebaseio.com
VITE_FIREBASE_PROJECT_ID=flygaca-app
VITE_FIREBASE_STORAGE_BUCKET=flygaca-app.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=30479965011
VITE_FIREBASE_APP_ID=1:30479965011:web:42fa30458ca85f30b91fa6
VITE_FIREBASE_MEASUREMENT_ID=G-D4Y38H2VK8
# VITE_RECAPTCHA_ENTERPRISE_SITE_KEY=

# Dev only: point Auth/Firestore at the local Firebase Emulator Suite.
# VITE_FIREBASE_EMULATOR=1
