# Copy to .env.local and fill in. All VITE_* vars are exposed to the client.

# Backend base for the chat/content gateway (default: /api, proxied by the host).
VITE_API_BASE=/api

# Where the ~130 MB regulatory data corpus is served from. Unset (default) → the
# app fetches it same-origin from /data (shipped in the Hosting release). Set to a
# bucket origin (e.g. https://storage.googleapis.com/<bucket>/data) to serve the
# corpus off the app host, keeping each Firebase Hosting release small so it can't
# exhaust the Hosting storage quota. Pair with the DATA_BASE_URL / DATA_BUCKET repo
# variables in deploy.yml. See docs/DATA-HOSTING.md.
# VITE_DATA_BASE_URL=

# Firebase web config (public, non-secret). When unset, the app runs fully
# local-first (no auth / no Firestore sync). Set at least the three required keys
# (apiKey, projectId, appId) to turn on Firebase. These are the real values for
# the `flygaca-app` project (Firebase console → Project settings → Your apps →
# Web) — public client identifiers, restricted by Firestore rules + App Check,
# not secrets. Copy this file to `.env.local` to initialize Firebase.
# NOTE: For security, replace the values below with your own Firebase project's
# web config values, or leave them blank and fill in via .env.local.
VITE_FIREBASE_API_KEY=AIzaSyCJUd5OS7GYgNYMQEiadVDEdw4MEQc-yaA
VITE_FIREBASE_AUTH_DOMAIN=flygaca-app.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://flygaca-app-default-rtdb.firebaseio.com
VITE_FIREBASE_PROJECT_ID=flygaca-app
VITE_FIREBASE_STORAGE_BUCKET=flygaca-app.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=30479965011
VITE_FIREBASE_APP_ID=1:30479965011:web:80330044431419d6b91fa6
VITE_FIREBASE_MEASUREMENT_ID=G-7WDWZE7C1X

# App Check (reCAPTCHA Enterprise) site key. When set, the client initializes
# App Check and attaches its token to gateway calls (X-Firebase-AppCheck on
# /api/chat; httpsCallable auto-attaches for createCheckoutSession) AND to
# Firebase Auth requests, so sign-in works while App Check is enforced on the
# project. Public client value (ships in the page), not a secret. The serving
# domain must be registered on this reCAPTCHA Enterprise key. When unset the app
# still runs but Auth is rejected under enforcement. See docs/APP-CHECK-BACKEND.md.
VITE_RECAPTCHA_ENTERPRISE_SITE_KEY=6Ld5bzItAAAAAG_20A4bjor43Iibk0xbUohhfNVA

# Dev only: point Auth/Firestore at the local Firebase Emulator Suite.
# VITE_FIREBASE_EMULATOR=1