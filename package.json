{
  "name": "flygaca-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Fly GACA — independent educational platform and open regulatory library for Saudi civil aviation. Modern TypeScript rebuild of the Fly GACA frontend.",
  "scripts": {
    "dev": "vite",
    "build:sitemap": "node scripts/build-sitemap.mjs",
    "build:airports": "node scripts/build-airports.mjs",
    "optimize:img": "node scripts/optimize-images.mjs",
    "gen:og": "node scripts/build-og-images.mjs",
    "build": "npm run build:sitemap && tsc -b && vite build && node scripts/prerender-head.mjs",
    "prerender": "node scripts/prerender.mjs",
    "sync:gaca": "node scripts/sync-gaca.mjs",
    "sync:gaca:apply": "node scripts/sync-gaca.mjs --apply",
    "gen:captain": "node scripts/generate-captain-adel.mjs",
    "new:guide": "node scripts/new-guide.mjs",
    "check:bundle": "node scripts/check-bundle.mjs",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"*.{ts,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:rules": "firebase emulators:exec --only firestore \"vitest run --config vitest.rules.config.ts\"",
    "test:e2e": "playwright test",
    "cap:sync": "npm run build && cap sync",
    "cap:open": "cap open ios",
    "serve": "npm run build && firebase emulators:start --only hosting",
    "deploy": "npm run build && npm run prerender && firebase deploy --only hosting",
    "deploy:rules": "firebase deploy --only firestore:rules",
    "deploy:functions": "firebase deploy --only functions",
    "deploy:all": "npm run build && npm run prerender && firebase deploy --only hosting,functions,firestore:rules"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/app": "^6.0.3",
    "@capacitor/browser": "^6.0.6",
    "@capacitor/ios": "^6.2.1",
    "@capacitor/keyboard": "^6.0.4",
    "@capacitor/preferences": "^6.0.4",
    "@capacitor/share": "^6.0.4",
    "@capacitor/splash-screen": "^6.0.4",
    "@capacitor/status-bar": "^6.0.3",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "firebase": "^11.10.0",
    "framer-motion": "^11.18.2",
    "i18next": "^23.16.8",
    "leaflet": "^1.9.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.2.0",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^6.2.0",
    "@cloudflare/workers-types": "^4.20260624.1",
    "@eslint/js": "^9.39.4",
    "@firebase/rules-unit-testing": "^4.0.1",
    "@playwright/test": "^1.61.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/leaflet": "^1.9.21",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "firebase-tools": "^15.22.2",
    "globals": "^15.14.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.4.2",
    "sharp": "^0.35.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vite": "^6.0.5",
    "vite-plugin-pwa": "^0.21.1",
    "vitest": "^4.1.9"
  }
}
