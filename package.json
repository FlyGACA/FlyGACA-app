{
  "name": "flygaca-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Fly GACA — independent educational platform and open regulatory library for Saudi civil aviation. Modern TypeScript rebuild of the Fly GACA frontend.",
  "scripts": {
    "dev": "vite",
    "build:sitemap": "node scripts/build-sitemap.mjs",
    "build:airports": "node scripts/build-airports.mjs",
    "build:chunks": "node scripts/build-rag-chunks.mjs",
    "optimize:img": "node scripts/optimize-images.mjs",
    "gen:og": "node scripts/build-og-images.mjs",
    "gen:aip-sheet": "node scripts/build-aip-study-sheet.mjs",
    "build": "npm run build:sitemap && tsc -b && vite build && node scripts/prerender-head.mjs && npm run check:prerender",
    "check:prerender": "node scripts/check-prerender.mjs",
    "prerender": "node scripts/prerender.mjs",
    "check:prerender:coverage": "node scripts/check-prerender-coverage.mjs",
    "sync:gaca": "node scripts/sync-gaca.mjs",
    "sync:gaca:apply": "node scripts/sync-gaca.mjs --apply && npm run data:normalize",
    "data:normalize": "node scripts/normalize-corpus-data.mjs",
    "lint:md": "markdownlint-cli2 \"content/regulations/**/*.md\"",
    "parse:regulations": "node scripts/parse-regulations.mjs",
    "embeddings:upsert": "node scripts/upsert-embeddings.mjs",
    "gen:captain": "node scripts/generate-captain-adel.mjs",
    "new:guide": "node scripts/new-guide.mjs",
    "check:bundle": "node scripts/check-bundle.mjs",
    "audit:ai": "node scripts/audit-ai-visibility.mjs",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"*.{ts,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "verify": "npm run typecheck && npm run lint && npm run format:check && npm run test && npm run build && npm run check:bundle",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:rules": "firebase emulators:exec --only firestore \"vitest run --config vitest.rules.config.ts\"",
    "test:e2e": "playwright test",
    "cap:sync": "npm run build && cap sync",
    "cap:open": "cap open ios",
    "serve": "npm run build && firebase emulators:start --only hosting",
    "deploy": "npm run build && npm run prerender && npm run check:prerender:coverage && firebase deploy --only hosting",
    "deploy:rules": "firebase deploy --only firestore:rules",
    "deploy:functions": "firebase deploy --only functions",
    "deploy:all": "npm run build && npm run prerender && npm run check:prerender:coverage && firebase deploy --only hosting,functions,firestore:rules"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/ios": "^8.4.1",
    "@capacitor/keyboard": "^8.0.5",
    "@capacitor/preferences": "^6.0.4",
    "@capacitor/share": "^6.0.4",
    "@capacitor/splash-screen": "^6.0.4",
    "@capacitor/status-bar": "^6.0.3",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/readex-pro": "^5.2.11",
    "@phosphor-icons/react": "^2.1.10",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "firebase": "^12.16.0",
    "framer-motion": "^12.42.2",
    "i18next": "^26.3.6",
    "leaflet": "^1.9.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.9",
    "react-router": "^8.2.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.1",
    "@cloudflare/workers-types": "^4.20260702.1",
    "@eslint/js": "^9.39.4",
    "@firebase/rules-unit-testing": "^4.0.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/leaflet": "^1.9.21",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "firebase-tools": "^15.23.0",
    "globals": "^17.7.0",
    "gray-matter": "^4.0.3",
    "jsdom": "^29.1.1",
    "markdownlint-cli2": "^0.23.0",
    "mdast-util-to-string": "^4.0.0",
    "prettier": "^3.9.5",
    "remark-parse": "^11.0.0",
    "sharp": "^0.35.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.63.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0",
    "vite": "^8.1.4",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9"
  }
}
