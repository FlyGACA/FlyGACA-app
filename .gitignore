# Dependencies
node_modules/

# Build output
dist/
dev-dist/
*.tsbuildinfo

# Coverage reports
coverage/

# Playwright
test-results/
playwright-report/
blob-report/
/playwright/.cache/

# Capacitor platform projects are generated on the Mac, never committed — and
# the per-flavor pipeline (scripts/flavor-ios.mjs) regenerates ios/ for ONE
# flavor at a time, so a committed project would always be the wrong app.
# See docs/RUNBOOK-native.md.
/ios/
/android/

# Xcode user state / caches
xcuserdata/
*.xcuserstate
DerivedData/

# Per-flavor staged public dir (built by scripts/build-flavor.mjs)
.flavor/

# Editor / OS
.DS_Store
.vscode/*
!.vscode/extensions.json
*.local

# Env
.env
.env.local
.env.*.local

# Firebase
.firebase/
firebase-debug.log
firestore-debug.log

# Cloudflare Wrangler (local dev cache + state)
.wrangler/

# Logs
npm-debug.log*
*.log
.vercel

# GACA sync — fetched source HTML/PDF assets (regenerated on demand)
sync-input/assets/

# Generated Captain Adel source art (regenerate via npm run gen:captain) — kept out of the deploy
captain-art/
