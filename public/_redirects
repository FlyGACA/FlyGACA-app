# SPA fallback (copied verbatim into dist/ by Vite; honored by Cloudflare Workers
# static assets and by Netlify alongside netlify.toml). The /api/* proxy is handled
# by the Worker in worker/index.ts — _redirects can't proxy external origins, and
# `run_worker_first = ["/api/*"]` in wrangler.toml runs the Worker before this
# fallback so it never swallows an API call.
/*    /index.html    200
